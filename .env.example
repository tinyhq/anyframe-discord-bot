# Required — points the SDK at the AnyFrame control plane.
ANYFRAME_BASE_URL=https://api.anyfrm.com
ANYFRAME_API_KEY=afm_xxx
ANYFRAME_AGENT_ID=1

# Required — Discord application bot token. The bot must have the
# Message Content Intent enabled in the Developer Portal.
DISCORD_BOT_TOKEN=

# SQLite path. Defaults to /data/state.db in Docker; mount a Railway Volume.
STATE_DB_PATH=./state.db

# How long to wait for a fresh / resumed sandbox to reach `running`.
BOOT_TIMEOUT_S=180
